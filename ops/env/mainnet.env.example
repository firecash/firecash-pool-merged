# Runtime config TEMPLATE for the mainnet katpool deployment
# (katpool-mainnet.service). Copy to ops/env/mainnet.env, fill in the
# host-specific values, then deploy with:  scripts/deploy.sh --network mainnet
#
# systemd EnvironmentFile format: KEY=value, one per line, no quoting/export.
# Installed to /etc/katpool/mainnet.env by scripts/deploy.sh.
#
# SECRETS: the treasury key is NEVER stored here or committed. Provision it
# out of band (per ADR-0003 / ADR-0008): either KATPOOL_TREASURY_KEY_PATH
# pointing at a root-only file, or a systemd LoadCredentialEncrypted named
# `treasury-key`. The treasury address is the first KATPOOL_POOL_ADDRESS.
#
# Optional layered config file (A3). Point KATPOOL_CONFIG at a YAML or TOML
# file to supply the core keys (node/db/network, stratum, maturity, toggles)
# from version control. Precedence is strict: env var > config file > default,
# so any KATPOOL_*/KASPAD_* line in THIS file still overrides the file. Unknown
# keys and out-of-range values abort the boot. Payout/KRC-20/consolidation and
# the treasury key stay env-only (secrets / money policy). Unset ⇒ pure-env.
# See ops/config/katpool.example.yaml.
# KATPOOL_CONFIG=/etc/katpool/mainnet.yaml

# Use a non-default mainnet DB and a strong password (not the testnet creds).
KATPOOL_DATABASE_URL=postgres://katpool:CHANGE_ME@127.0.0.1:5432/katpool_mainnet
# Mainnet kaspad gRPC endpoint on this host.
KASPAD_GRPC_URL=grpc://127.0.0.1:16110
# Mainnet pool/treasury address(es), comma-separated (kaspa: prefix).
KATPOOL_POOL_ADDRESS=kaspa:CHANGE_ME
# Cutover DAA floor (default 0 = disabled). When adopting a treasury address a
# prior pool already mined to, set this to the cutover virtual DAA score so the
# accountant ignores the prior pool's historical coinbase UTXOs (never recorded
# or allocated — they were already paid out by the prior pool). See Runbook 22.
# KATPOOL_COINBASE_MIN_DAA_SCORE=
KATPOOL_STRATUM_PORT=5555
# Multi-port stratum binding for zero-action cutover (ADR-0022). Binds all
# legacy ports with their per-port STARTING-difficulty seed; vardiff then
# moves each miner freely from there. Seeds mirror the legacy pool's port
# table. Leave empty to bind only KATPOOL_STRATUM_PORT.
KATPOOL_STRATUM_PORTS=1111:256,2222:1024,3333:4096,4444:8192,5555:16384,6666:32768,7777:65536,8888:2048
# Require + parse PROXY protocol v2 on every stratum connection so the real
# miner IP is recovered behind the fly.io anycast edge (ADR-0022). MUST be
# paired with nftables allowlisting the fly egress on ports 1111-8888 — see
# ops/edge/flyio/README.md. Set false only for direct (un-fronted) testing.
KATPOOL_STRATUM_PROXY_PROTOCOL=true
KATPOOL_INSTANCE_ID=mainnet
KATPOOL_MATURITY_POLL_SECS=15

# Wallet-tier classifier (ADR-0012). On mainnet set `kasplex` so the NACHO Elite
# rebate is actually applied from on-chain holdings (the kasplex indexers are
# mainnet-only). Any upstream failure falls back to Standard (never over-rebates)
# and a circuit breaker stops hammering a degraded indexer. `static` (the binary
# default) marks every wallet Standard and leaves the Elite rebate inert.
KATPOOL_TIER_CLASSIFIER=kasplex

# Graceful-shutdown backlog drain ceiling (seconds, default 10). At SIGTERM the
# consumer persists every event already on the bus before exiting, bounded here.
# KATPOOL_SHUTDOWN_DRAIN_SECS=10

# Log format. On mainnet prefer json once log shipping to Loki is live so logs
# are queryable; text remains valid for direct journalctl reading.
KATPOOL_LOG_FORMAT=json
# OpenTelemetry trace export (ADR-0004). Point at the LOCAL origin Alloy OTLP/gRPC
# receiver (127.0.0.1:4317), which forwards spans to Tempo through vmauth (see
# ops/railway/observability/origin/). The pool exporter is gRPC-only with no auth,
# so it must target a local collector, never Tempo directly. Unset disables export.
# KATPOOL_OTLP_ENDPOINT=http://127.0.0.1:4317
# OTEL_SERVICE_NAME=  # overrides service.name (defaults to KATPOOL_INSTANCE_ID)

# Observability — export bridge + accountant Prometheus metrics. Enabling it
# also activates the anti-abuse counters (init_metrics runs only when the
# exporter starts). On mainnet do NOT expose this publicly: bind it to
# loopback or a private interface and reach it from the scraper over that
# path / firewall the port. Format "HOST:PORT" or ":PORT" (":PORT" = 0.0.0.0).
KATPOOL_PROM_PORT=127.0.0.1:9302

# Public read-only HTTP API (Phase 6, ADR-0021). Bind address host:port; leave
# empty to disable. Bind to loopback and let nginx terminate TLS + proxy to it
# (it honors a single trusted X-Forwarded-For hop for per-IP rate limiting).
# Serves /health /ready /started + the versioned /api/v1 read-only surface.
# The API reads PostgreSQL only — provision a least-privilege read-only DB role
# for it on mainnet (threat-model §4.6).
KATPOOL_API_PORT=127.0.0.1:8080
# Least-privilege read-only DB URL for the API (ADR-0021). On mainnet this SHOULD
# be set: the API connects as a SELECT-only role isolated from the writers' pool.
# Provision the role with ops/db/api-readonly-role.sql; keep the password here only.
KATPOOL_API_DATABASE_URL=postgres://katpool_api:CHANGE_ME@127.0.0.1:5432/katpool_mainnet

# Dedicated liveness/readiness probe port ("HOST:PORT" or ":PORT"; empty
# disables). Serves only /health /ready /started — no rate limiter, no /api/v1 —
# off the same readiness source as the API, so orchestrators can health-check
# independently of the public API. /ready is DB-reachable AND kaspad-synced.
KATPOOL_HEALTH_CHECK_PORT=
# Per-IP rate limit (tower-governor GCRA). The binary default (5/sec sustained,
# 20 burst) assumes distinct public clients — but on mainnet the dashboard's
# same-origin Next BFF fronts this API, so every viewer + poll arrives as ONE
# source IP and the per-IP budget is effectively global. One overview load fans
# out to ~8 v1 endpoints at once, so the default would throttle legitimate
# traffic. These BFF-appropriate values keep headroom for cold starts and
# miner-page fan-out while still bounding a runaway client; tune to the real
# viewer load. (If you ever expose the API to distinct public clients directly,
# revert toward the 5/20 default.)
KATPOOL_API_RATE_PER_SECOND=100
KATPOOL_API_RATE_BURST=300
# Per-request hard timeout (HTTP backstop above the DB statement_timeout).
# KATPOOL_API_REQUEST_TIMEOUT_SECS=10
# moka TTL caches — pool-wide aggregates/series vs. shorter per-wallet reads.
# KATPOOL_API_POOL_CACHE_TTL_SECS=10
# KATPOOL_API_WALLET_CACHE_TTL_SECS=5
# CORS allow-origin; empty installs no CORS layer (dashboard served same-origin).
# KATPOOL_API_CORS_ALLOW_ORIGIN=https://dashboard.example.com

# Optional miner geo distribution (ADR-0025). Path to a MaxMind GeoLite2/GeoIP2
# Country .mmdb; the accountant tags each closing session with an ISO-3166
# country for the aggregate-only /api/v1/pool/geo view. Unset/unreadable ⇒ geo
# disabled (NULL country), non-fatal. Provision the DB out-of-band (geoipupdate
# with a MaxMind license key) and keep it <30 days old per the GeoLite EULA.
# KATPOOL_GEOIP_DB=/etc/katpool/GeoLite2-Country.mmdb

# Stratum difficulty tuning (defaults if unset: 4096 / true / 20). Tune
# `KATPOOL_MIN_SHARE_DIFF` upward for higher-hashrate fleets so vardiff
# starts close to each miner's steady-state difficulty.
KATPOOL_MIN_SHARE_DIFF=
KATPOOL_VAR_DIFF=
KATPOOL_SHARES_PER_MIN=

RUST_LOG=info,accountant=info,kaspa_stratum_bridge=info

# Payouts start disabled; enable only after a clean mainnet rehearsal
# (Runbooks 18 & 19). Flip these deliberately once the cycle is verified:
KATPOOL_PAYOUT_ENABLED=false
KATPOOL_PAYOUT_DRY_RUN=true
KATPOOL_KRC20_PAYOUT_ENABLED=false
KATPOOL_KRC20_PAYOUT_DRY_RUN=true
#
# Cadence + thresholds (ADR-0018). Same defaults as tn10: cycles are bucketed
# by virtual DAA score (NOT wall-clock), so the span is in DAA units and is
# block-rate-specific. Mainnet runs 10 blocks/sec since the Crescendo hardfork,
# so 6h ≈ 6*3600*10 = 216_000 DAA. Span must exceed the 100-DAA confirmation
# depth. Thresholds below are 10 KAS. These match the built-in binary defaults,
# so they only need setting here to override:
# KATPOOL_PAYOUT_CYCLE_SPAN_DAA=216000
# KATPOOL_PAYOUT_THRESHOLD_SOMPI=1000000000
# KATPOOL_KRC20_PAYOUT_CYCLE_SPAN_DAA=216000
# KATPOOL_KRC20_MIN_PENDING_SOMPI=1000000000
#
# Money-safety per-cycle spend caps (G1). Hard circuit breakers: a cycle whose
# total non-failed outbound exceeds the cap is REFUSED before any broadcast/
# settle — funds stay put until an operator raises the cap or fixes the input
# (e.g. a poisoned floor-price quote). Unset = disabled; SET BOTH on mainnet to
# a ceiling comfortably above a normal cycle yet far below the treasury balance.
# KAS cap is in sompi; NACHO cap is in base units (8 decimals). Tune from the
# observed steady-state cycle totals after the first live cycles.
# KATPOOL_PAYOUT_MAX_SOMPI_PER_CYCLE=
# KATPOOL_KRC20_MAX_NACHO_PER_CYCLE=
#
# Treasury UTXO consolidation engine ("Maintain" layer). Compounds many small
# spendable coins into a few large ones via mass-valid N->1 self-sends so large
# single-recipient KAS payouts can be funded within the per-tx mass limit.
# Shares the treasury key and the single treasury:spend-leader advisory lock
# with the payout engines, so only one treasury spender acts per tick. Starts
# off + dry-run; validate on TN10 first, then on mainnet run dry-run (confirm
# planned batch counts in the logs) before flipping DRY_RUN=false.
#
# Hysteresis: a sweep STARTS once the spendable UTXO count exceeds
# TRIGGER_UTXO_COUNT and compounds down each tick to TARGET_UTXO_COUNT, then
# rests until the count climbs back above the trigger. The mempool standard-mass
# limit (100k grams) is the real per-tx guard and caps a one-output self-send
# near ~88 inputs, so MAX_INPUTS_PER_TX=80 fits with headroom (350 would be
# rejected at broadcast as non-standard). MAX_TXS_PER_TICK is sweep throughput.
# A tick exceeding TICK_TIMEOUT_SECS is abandoned and the lock released so a hung
# kaspad RPC can never wedge the payout engines.
KATPOOL_CONSOLIDATION_ENABLED=false
KATPOOL_CONSOLIDATION_DRY_RUN=true
# KATPOOL_CONSOLIDATION_POLL_SECS=120
# KATPOOL_CONSOLIDATION_TICK_TIMEOUT_SECS=120
# KATPOOL_CONSOLIDATION_TRIGGER_UTXO_COUNT=1000
# KATPOOL_CONSOLIDATION_TARGET_UTXO_COUNT=50
# KATPOOL_CONSOLIDATION_MAX_INPUTS_PER_TX=80
# KATPOOL_CONSOLIDATION_MAX_TXS_PER_TICK=50
#
# Operator on-demand payout (does not require the periodic engine):
#   katpool payout run-now [--dry-run]   # drive one cycle now, then exit

# --- MiningPoolStats listing (GET /api/pool/miningPoolStats) ------------------
# Legacy-compatible aggregator feed (miningpoolstats.stream). The endpoint is
# always served; these only tune the DISPLAY metadata and all have sane defaults
# (shown). poolFee is display-only via KATPOOL_MPS_FEE_BPS (default 50 = 0.5%);
# real allocations use KATPOOL_FEE_TOPLINE_BPS (default 75 = 0.75%). The per-block
# pool_address echoes the first KATPOOL_POOL_ADDRESS. NOTE: advertise_image_link is retained
# for legacy shape parity only — MiningPoolStats does not render it (verified).
# KATPOOL_MPS_POOL_NAME=Kat Pool
# KATPOOL_MPS_URL=app.katpool.com
# KATPOOL_MPS_COUNTRY=US
# KATPOOL_MPS_FEE_TYPE=PROP
# KATPOOL_MPS_MIN_PAY_KAS=10
# KATPOOL_MPS_AD_IMAGE_LINK=https://app.katpool.xyz/images/katpoolad.gif
# KATPOOL_MPS_FEE_BPS=50
