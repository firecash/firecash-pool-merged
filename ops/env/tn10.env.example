# Runtime config for the testnet-10 katpool deployment (katpool-tn10.service).
# systemd EnvironmentFile format: KEY=value, one per line, no quoting/export.
# Installed to /etc/katpool/tn10.env by scripts/deploy.sh.
#
# The network is implied by the kaspad endpoint + the kaspatest: address
# prefix; the binary itself is network-agnostic. No secrets live here — the
# treasury key (only needed once payouts leave dry-run) is provisioned out of
# band via KATPOOL_TREASURY_KEY_PATH or a systemd encrypted credential.
#
# Optional layered config file (A3). Point KATPOOL_CONFIG at a YAML or TOML
# file to supply the core keys (node/db/network, stratum, maturity, toggles)
# from version control. Precedence is strict: env var > config file > default,
# so any KATPOOL_*/KASPAD_* line in THIS file still overrides the file. Unknown
# keys and out-of-range values abort the boot. Payout/KRC-20/consolidation and
# the treasury key stay env-only (secrets / money policy). Unset ⇒ pure-env.
# See ops/config/katpool.example.yaml.
# KATPOOL_CONFIG=/etc/katpool/tn10.yaml

KATPOOL_DATABASE_URL=
KASPAD_GRPC_URL=
KATPOOL_POOL_ADDRESS=
KATPOOL_STRATUM_PORT=
KATPOOL_INSTANCE_ID=
KATPOOL_MATURITY_POLL_SECS=

# Wallet-tier classifier (ADR-0012). Default `static` (every wallet Standard;
# the NACHO Elite rebate is inert) — correct for the tn10 soak, since the
# kasplex indexers are mainnet-only and testnet wallets resolve as Standard.
# `kasplex` is for mainnet.
# KATPOOL_TIER_CLASSIFIER=static

# Graceful-shutdown backlog drain ceiling (seconds, default 10).
# KATPOOL_SHUTDOWN_DRAIN_SECS=10

# Log format: text (default; journalctl-friendly) or json. Set json so the
# origin Alloy agent ships structured fields to Loki (ops/railway/observability/
# origin/). Verbosity is controlled by RUST_LOG below.
# KATPOOL_LOG_FORMAT=json
# OpenTelemetry trace export (ADR-0004). Point at the LOCAL origin Alloy OTLP/gRPC
# receiver (127.0.0.1:4317); Alloy forwards spans to Tempo through vmauth. Leave
# unset to disable export. The pool exporter is gRPC-only with no auth, so it
# must target a local collector, never a remote endpoint directly.
# KATPOOL_OTLP_ENDPOINT=http://127.0.0.1:4317
# OTEL_SERVICE_NAME=  # overrides service.name (defaults to KATPOOL_INSTANCE_ID)

# Observability — export bridge + accountant Prometheus metrics on this port.
# Format ":PORT" binds 0.0.0.0:PORT, served at GET /metrics (instance-filtered).
# Leave empty to disable. Enabling it also activates the anti-abuse counters
# (init_metrics runs only when the exporter starts).
KATPOOL_PROM_PORT=

# Public read-only HTTP API (Phase 6, ADR-0021). Bind address host:port (e.g.
# 127.0.0.1:8080) or :port (all interfaces); leave empty to disable. nginx
# terminates TLS and proxies to it. Serves the unversioned /health /ready
# /started probes plus the versioned /api/v1 read-only surface.
KATPOOL_API_PORT=
# Optional least-privilege read-only DB URL for the API (ADR-0021 hardening).
# When set, the API connects as a SELECT-only role isolated from the writers'
# pool; unset ⇒ it shares KATPOOL_DATABASE_URL. Provision the role with
# ops/db/api-readonly-role.sql. Keep the password here only.
# KATPOOL_API_DATABASE_URL=postgres://katpool_api:CHANGE_ME@127.0.0.1:55432/katpool_tn10

# Dedicated liveness/readiness probe port (host:port or :port; empty disables).
# Serves only /health /ready /started — no rate limiter, no /api/v1 — using the
# same readiness source as the API, so orchestrators (systemd/Railway) can
# health-check even when KATPOOL_API_PORT is off. /ready is DB-reachable AND
# kaspad-synced. Safe to run alongside or instead of the public API.
KATPOOL_HEALTH_CHECK_PORT=
# Per-IP rate limit (tower-governor GCRA). Defaults: 5/sec sustained, 20 burst.
# Those defaults assume distinct public clients. When the dashboard's same-origin
# Next BFF fronts this API, every viewer + poll arrives as ONE source IP, so the
# per-IP budget is effectively global and the defaults throttle legitimate
# traffic (one overview load fans out to ~8 v1 endpoints at once). Size it for
# the BFF deployment — e.g. 100/sec sustained, 300 burst — with headroom for
# cold starts and miner-page fan-out while still bounding a runaway client.
# KATPOOL_API_RATE_PER_SECOND=100
# KATPOOL_API_RATE_BURST=300
# Per-request hard timeout (HTTP backstop above the DB statement_timeout).
# KATPOOL_API_REQUEST_TIMEOUT_SECS=10
# moka TTL caches — pool-wide aggregates/series vs. shorter per-wallet reads.
# KATPOOL_API_POOL_CACHE_TTL_SECS=10
# KATPOOL_API_WALLET_CACHE_TTL_SECS=5
# CORS allow-origin; empty installs no CORS layer (dashboard served same-origin).
# KATPOOL_API_CORS_ALLOW_ORIGIN=

# Optional miner geo distribution (ADR-0025). Path to a MaxMind GeoLite2/GeoIP2
# Country .mmdb; the accountant tags each closing session with an ISO-3166
# country for the aggregate-only /api/v1/pool/geo view. Unset/unreadable ⇒ geo
# disabled (NULL country), non-fatal. Provision the DB out-of-band (geoipupdate
# with a MaxMind license key) and keep it <30 days old per the GeoLite EULA.
# KATPOOL_GEOIP_DB=/etc/katpool/GeoLite2-Country.mmdb

# Stratum difficulty tuning (defaults if unset: 4096 / true / 20). Lower
# `KATPOOL_MIN_SHARE_DIFF` only for CPU/dev miners; setting it too low for
# real ASICs causes a stale-share storm against tn10's fast block rate.
KATPOOL_MIN_SHARE_DIFF=
KATPOOL_VAR_DIFF=
KATPOOL_SHARES_PER_MIN=

RUST_LOG=info,accountant=debug,kaspa_stratum_bridge=info

# Payout engines stay off / dry-run by default during the soak. Enable
# deliberately once the cycle has been rehearsed (Runbooks 18 & 19):
# KATPOOL_PAYOUT_ENABLED=true
# KATPOOL_PAYOUT_DRY_RUN=false
# KATPOOL_KRC20_PAYOUT_ENABLED=true
# KATPOOL_KRC20_PAYOUT_DRY_RUN=false
#
# Cadence + thresholds (ADR-0018). Cycles are bucketed by virtual DAA score,
# NOT wall-clock, so the span is in DAA units and is block-rate-specific:
# tn10-toc3 runs ~10 blocks/sec, so 6h ≈ 6*3600*10 = 216_000 DAA. Span must
# exceed the 100-DAA confirmation depth. Thresholds below are 10 KAS. These
# match the built-in binary defaults, so they only need setting here to override.
# KATPOOL_PAYOUT_CYCLE_SPAN_DAA=216000
# KATPOOL_PAYOUT_THRESHOLD_SOMPI=1000000000
# KATPOOL_KRC20_PAYOUT_CYCLE_SPAN_DAA=216000
# KATPOOL_KRC20_MIN_PENDING_SOMPI=1000000000
#
# Money-safety per-cycle spend caps (G1). Optional on tn10 but useful to
# rehearse: a cycle whose total non-failed outbound exceeds the cap is refused
# before any broadcast/settle. KAS cap in sompi; NACHO cap in base units.
# Unset = disabled.
# KATPOOL_PAYOUT_MAX_SOMPI_PER_CYCLE=
# KATPOOL_KRC20_MAX_NACHO_PER_CYCLE=
#
# Treasury UTXO consolidation engine ("Maintain" layer). Compounds many small
# spendable coins into a few large ones via mass-valid N->1 self-sends so large
# single-recipient KAS payouts can be funded within the per-tx mass limit.
# Shares the treasury key and the single treasury:spend-leader advisory lock
# with the payout engines, so only one treasury spender acts per tick. Off +
# dry-run by default. Hysteresis: a sweep STARTS once the spendable UTXO count
# exceeds TRIGGER_UTXO_COUNT and compounds down each tick to TARGET_UTXO_COUNT
# (e.g. 1), then rests until the count climbs back above the trigger. The
# mempool standard-mass limit (100k grams) is the real per-tx guard and caps a
# one-output self-send near ~88 inputs, so MAX_INPUTS_PER_TX=80 fits with
# headroom (350 would be rejected at broadcast as non-standard). MAX_TXS_PER_TICK
# is sweep throughput (disjoint batches per tick). A tick exceeding
# TICK_TIMEOUT_SECS is abandoned and the lock released (hung-RPC safety).
# Roll out on TN10 dry-run first (confirm "planned" batch counts in the logs),
# then flip DRY_RUN=false; a few ticks collapse the fragmented set.
# KATPOOL_CONSOLIDATION_ENABLED=true
# KATPOOL_CONSOLIDATION_DRY_RUN=false
# KATPOOL_CONSOLIDATION_POLL_SECS=120
# KATPOOL_CONSOLIDATION_TICK_TIMEOUT_SECS=120
# KATPOOL_CONSOLIDATION_TRIGGER_UTXO_COUNT=1000
# KATPOOL_CONSOLIDATION_TARGET_UTXO_COUNT=50
# KATPOOL_CONSOLIDATION_MAX_INPUTS_PER_TX=80
# KATPOOL_CONSOLIDATION_MAX_TXS_PER_TICK=50
#
# Operator on-demand payout (does not require the periodic engine):
#   katpool payout run-now [--dry-run]   # drive one cycle now, then exit
