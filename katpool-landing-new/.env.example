# Public pool API (no trailing slash). SSR uses this; the browser polls same-origin BFF.
NEXT_PUBLIC_POOL_API_URL=https://api.katpool.com
# Optional server-only override for the BFF upstream (defaults to NEXT_PUBLIC_POOL_API_URL).
# POOL_API_URL=https://api.katpool.com

# Dashboard / app CTA target.
NEXT_PUBLIC_APP_URL=https://app.katpool.com

# Stratum connection facts (defaults mirror production topology).
NEXT_PUBLIC_STRATUM_HOST=kas.katpool.com
# NEXT_PUBLIC_STRATUM_PORTS=1111:256,2222:1024,3333:4096,4444:8192,5555:16384,6666:32768,7777:65536,8888:2048

# Open-source repository link.
NEXT_PUBLIC_GITHUB_URL=https://github.com/Nacho-the-Kat/katpool

# Official X / Twitter profile (drives the @handle in metadata + UI links).
NEXT_PUBLIC_TWITTER_URL=https://x.com/Katpool_Mining

# Public site URL (metadata / OG / canonical). This is the CANONICAL host:
# the middleware 308-redirects the alias hosts below to this origin.
NEXT_PUBLIC_SITE_URL=https://katpool.com

# Comma-separated alias hosts to redirect to NEXT_PUBLIC_SITE_URL's host.
# Defaults to katpool.xyz,www.katpool.xyz,www.katpool.com when unset.
# IMPORTANT: remove any registrar/Railway rule that forwards .com -> .xyz, or
# it will fight this redirect and loop.
# NEXT_PUBLIC_CANONICAL_REDIRECT_HOSTS=katpool.xyz,www.katpool.xyz,www.katpool.com
