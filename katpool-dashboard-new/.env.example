# --- katpool v1 API (read-only, server-side) -------------------------------
# Base URL of the unified katpool HTTP API. No trailing slash.
KATPOOL_API_BASE_URL=https://kas.katpool.com/api/v1

# --- Kaspa public API (network context) ------------------------------------
# Public REST API used for network hashrate / difficulty / supply / halving.
KASPA_API_BASE_URL=https://api.kaspa.org

# --- Price oracle: CoinGecko (server-side only) ----------------------------
# Demo/Pro key. Held server-side; never exposed to the browser.
COINGECKO_API_KEY=
# Use "pro" only if you hold a CoinGecko Pro key; otherwise leave as "demo".
COINGECKO_PLAN=demo

# --- Explorer / external links (public, client-safe) -----------------------
NEXT_PUBLIC_EXPLORER_BASE_URL=https://explorer.kaspa.org

# --- Public URLs (metadata / OG / canonical / sitemap) ---------------------
# Brand/marketing site — used as the Organization URL + cross-links in JSON-LD.
NEXT_PUBLIC_SITE_URL=https://katpool.com
# This dashboard's OWN public origin — drives metadataBase, canonical, sitemap
# and robots host. Must be the host this app is actually served on.
NEXT_PUBLIC_APP_URL=https://app.katpool.com

# --- Social / open source (public) -----------------------------------------
NEXT_PUBLIC_TWITTER_URL=https://x.com/Katpool_Mining
NEXT_PUBLIC_GITHUB_URL=https://github.com/Nacho-the-Kat/katpool

# --- Branding (public) -----------------------------------------------------
NEXT_PUBLIC_POOL_NAME=katpool

# --- Start-mining guide (public) -------------------------------------------
# Connection facts shown on /start. Defaults mirror the verified production
# topology in docs/cutover-stratum-compatibility.md, so leaving these unset
# renders the mainnet origin + 7-region edge + eight ports automatically.
# Override per deployment (e.g. a single-port testnet pool) to keep the guide
# accurate.
#   NEXT_PUBLIC_POOL_NETWORK   mainnet | testnet-10 (drives address prefix + faucet copy)
#   NEXT_PUBLIC_STRATUM_HOST   primary stratum host, e.g. kas.katpool.com
#   NEXT_PUBLIC_STRATUM_PORTS  override "port:seed,port:seed" (e.g. 15555:4096)
NEXT_PUBLIC_POOL_NETWORK=mainnet
# NEXT_PUBLIC_STRATUM_HOST=kas.katpool.com
# NEXT_PUBLIC_STRATUM_PORTS=
